# ==========================================
# CONFIGURACIÓN FRONTEND - LABORIA
# ==========================================
# Copia este archivo a .env y ajusta los valores

# URL del Backend Laboria (desarrollo)
VITE_API_URL=http://localhost:3000

# URL del Backend Laboria (producción)
# VITE_API_URL=https://tu-api.railway.app

# ==========================================
# SEGURIDAD - CLAVE MAESTRA ADMIN
# ==========================================
# Esta clave es necesaria para acceder al panel de administración
# en la URL: /admin/api-status
# 
# IMPORTANTE: Cambia esta clave por defecto en producción!
VITE_ADMIN_KEY=laboria2024

# ==========================================
# NOTAS DE CONFIGURACIÓN
# ==========================================
# 1. En desarrollo: backend corre en puerto 3000
# 2. El frontend corre en puerto 5173 (Vite) o 3000 si usas --port 3000
# 3. La clave maestra protege el panel de estado de APIs
# 4. La sesión de admin expira después de 1 hora
# 5. Después de 3 intentos fallidos, el acceso se bloquea por 5 minutos
