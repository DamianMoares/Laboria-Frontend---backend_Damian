# ==========================================
# CONFIGURACIÓN BACKEND - LABORIA
# ==========================================
# Copia este archivo a .env y ajusta los valores

# Base de Datos PostgreSQL (Railway proporcionará esta URL)
DATABASE_URL=postgresql://username:password@host:port/database

# JWT Secret (genera uno nuevo para producción)
JWT_SECRET=tu-super-secreto-jwt-min-32-caracteres-aqui

# JWT Expiration
JWT_EXPIRES_IN=7d

# Servidor
NODE_ENV=production
PORT=3000

# ==========================================
# NOTAS DE CONFIGURACIÓN
# ==========================================
# 1. Railway configurará automáticamente DATABASE_URL
# 2. Genera un JWT_SECRET único para producción
# 3. No incluyas este archivo .env en el repositorio
# 4. Mantén las credenciales seguras
